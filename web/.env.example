# Base URL for the CircleK proxy API.
# Leave blank to use the Vite dev proxy (/api -> http://localhost:5180).
# Set to an absolute URL (e.g. https://proxy.example.com) for a deployed build.
VITE_API_BASE=

# RouteScreen map hero uses Leaflet. By default it renders a free, no-token
# CARTO light basemap, so the next three vars are all OPTIONAL.

# Optional raster tile URL override (e.g. another free provider). Wins over the
# Mapbox vars below when set. Use {s}/{z}/{x}/{y} placeholders.
VITE_MAP_TILES_URL=

# Optional: render the designer's Mapbox Studio theme as raster tiles in Leaflet.
# Set BOTH to use it. Token is a public pk...., style is the Studio URL.
# (Leaflet can't load Mapbox GL vector styles natively — these go via the
# Mapbox Static Tiles API.)
VITE_MAPBOX_TOKEN=
VITE_MAPBOX_STYLE=mapbox://styles/<account>/<style-id>
